{
    "extends": "@repo/config/nextjs.json",
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "@/*": ["./src/*"],
            "~sanity/*": ["./sanity/*"],
            "@components/*": ["./src/components/*"],
            "@app/*": ["./src/app/*"],
            "@apps/web/*": ["./*"],
            "@repo/ui/*": ["../../packages/ui/src/*"],
        },
    },
    "include": [
        "next-env.d.ts",
        "**/*.ts",
        "**/*.tsx",
        ".next/types/**/*.ts",
        ".next/dev/types/**/*.ts",
    ],
    "exclude": ["node_modules", "generated"],
}
