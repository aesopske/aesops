# Copy to .env.local (git-ignored) to enable `--upload` on any scraper's main.py.
# Create the API key from the platform's admin API key UI, scoped to `datasets: ['write']`.

AESOPS_API_KEY=
# Defaults to http://localhost:3000 if unset — point at a deployed instance to upload there.
AESOPS_API_URL=

# sentry project
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_DSN=""
