{
    "extends": "@repo/config/base.json",
    "compilerOptions": {
        "baseUrl": ".",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "jsx": "react-jsx",
        // avoids TS2742 naming an unreachable zod v4 type from better-auth's internals
        "declaration": false,
        "declarationMap": false
    },
    "include": ["**/*.ts"],
    "exclude": ["node_modules"]
}
