{
  "name": "@repo/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts",
    "./schema/*": "./src/schema/*.ts"
  },
  "scripts": {
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:reset-comments": "node --env-file=.env scripts/reset-comments.mjs",
        "db:add-thread-slug": "node --env-file=.env scripts/add-thread-slug.mjs",
        "db:add-comment-votes": "node --env-file=.env scripts/add-comment-votes.mjs",
        "db:add-parquet-key": "node --env-file=.env scripts/add-parquet-key.mjs",
        "db:add-ai-usage-events": "node --env-file=.env scripts/add-ai-usage-events.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@repo/env": "workspace:*",
    "@neondatabase/serverless": "^0.10.4",
    "drizzle-orm": "^0.43.1"
  },
  "devDependencies": {
    "@repo/config": "workspace:*",
    "@types/node": "^22.15.3",
    "drizzle-kit": "^0.31.1",
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@10.10.0"
}
