{
  "name": "aesops-monorepo",
  "private": true,
  "packageManager": "pnpm@10.10.0",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "prepare": "husky",
    "check-types": "tsc --noEmit"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "eslint": "9.26.0",
    "husky": "^9.1.7",
    "prettier": "^3.5.3",
    "turbo": "^2.9.3",
    "typescript": "^5.8.3"
  },
  "pnpm": {
    "ignoredBuiltDependencies": [
      "@parcel/watcher",
      "@vercel/speed-insights",
      "core-js",
      "esbuild",
      "sharp"
    ]
  }
}
